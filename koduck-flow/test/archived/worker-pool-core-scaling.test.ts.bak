import { afterEach, beforeEach, describe, expect, it, vi } from "vitest";
import { WorkerPoolCore } from "../../../src/common/worker-pool/worker-pool-core";
import type { WorkerPoolConfig } from "../../../src/common/worker-pool/types";

describe("WorkerPoolCore - Scaling Operations", () => {
  let core: WorkerPoolCore;
  let config: WorkerPoolConfig;

  beforeEach(() => {
    // Base configuration
    config = {
      workerCount: 2,
      minWorkerCount: 2,
      maxWorkerCount: 10,
      defaultTaskTimeout: 5000,
      maxRetries: 0,
    };

    core = new WorkerPoolCore(config);
  });

  afterEach(async () => {
    await core.dispose();
    vi.clearAllTimers();
  });

  describe("Scale Up Operations", () => {
    it("should scale up workers concurrently", async () => {
      await core.initialize();

      const initialStats = core.getStats();
      expect(initialStats.total).toBe(2);

      // Scale up by 3
      await core.scaleUp(3);

      const stats = core.getStats();
      expect(stats.total).toBe(5);
      expect(stats.idle).toBe(5);
    });

    it("should emit scaled-up event with correct count", async () => {
      await core.initialize();

      const scaledUpSpy = vi.fn();
      core.on("scaled-up", scaledUpSpy);

      await core.scaleUp(2);

      expect(scaledUpSpy).toHaveBeenCalledWith(2, 4);
    });

    it("should warmup workers after creation", async () => {
      await core.initialize();

      // Scale up should trigger warmup
      await core.scaleUp(1);

      // Workers should be in idle state after warmup
      const stats = core.getStats();
      expect(stats.idle).toBe(3);
    });

    it("should handle partial failures during concurrent creation", async () => {
      await core.initialize();

      const scaleErrorSpy = vi.fn();
      core.on("scale-error", scaleErrorSpy);

      // Try to scale up beyond max
      await expect(core.scaleUp(10)).rejects.toThrow("would exceed maxWorkers");

      // Should have emitted scale-error events
      expect(scaleErrorSpy).toHaveBeenCalled();
    });

    it("should enforce max worker limit", async () => {
      await core.initialize();

      // Try to scale up beyond max (current 2 + 9 = 11 > max 10)
      await expect(core.scaleUp(9)).rejects.toThrow(
        "Cannot scale up: would exceed maxWorkers (10)"
      );

      const stats = core.getStats();
      expect(stats.total).toBe(2); // Should remain at initial count
    });

    it("should prevent concurrent scale operations with mutex", async () => {
      await core.initialize();

      // Start two scale operations concurrently
      const scale1 = core.scaleUp(2);
      const scale2 = core.scaleUp(2);

      // One should fail with mutex error
      await expect(Promise.all([scale1, scale2])).rejects.toThrow(
        "Scaling operation already in progress"
      );
    });

    it("should validate count parameter", async () => {
      await core.initialize();

      // Zero count should be no-op
      await core.scaleUp(0);

      const stats = core.getStats();
      expect(stats.total).toBe(2);
    });

    it("should handle negative count", async () => {
      await core.initialize();

      // Negative count should be no-op
      await core.scaleUp(-1);

      const stats = core.getStats();
      expect(stats.total).toBe(2);
    });
  });

  describe("Scale Down Operations", () => {
    beforeEach(async () => {
      // Start with more workers
      config.minWorkerCount = 2;
      core = new WorkerPoolCore(config);
      await core.initialize();
      await core.scaleUp(3); // Now have 5 workers
    });

    it("should scale down idle workers", async () => {
      const initialStats = core.getStats();
      expect(initialStats.total).toBe(5);

      const terminated = await core.scaleDown(2);

      expect(terminated).toBe(2);

      const stats = core.getStats();
      expect(stats.total).toBe(3);
    });

    it("should emit scaled-down event with correct count", async () => {
      const scaledDownSpy = vi.fn();
      core.on("scaled-down", scaledDownSpy);

      await core.scaleDown(2);

      expect(scaledDownSpy).toHaveBeenCalledWith(2, 3);
    });

    it("should select longest idle workers first (LRU strategy)", async () => {
      // Get idle workers
      const idleWorkers = core.getIdleWorkers();
      expect(idleWorkers.length).toBe(5);

      // Manually update lastActivityAt to create different idle times
      const workers = Array.from(idleWorkers);
      const now = Date.now();

      // Make first worker most recently active
      if (workers[0]) workers[0].lastActivityAt = now;
      // Make second worker idle for 1 second
      if (workers[1]) workers[1].lastActivityAt = now - 1000;
      // Make third worker idle for 2 seconds
      if (workers[2]) workers[2].lastActivityAt = now - 2000;

      const terminated = await core.scaleDown(1);
      expect(terminated).toBe(1);

      // Verify the longest idle worker was terminated
      // (We can't directly check which one, but we know one was removed)
      const stats = core.getStats();
      expect(stats.total).toBe(4);
    });

    it("should respect minimum worker count", async () => {
      // Scale down to minimum
      const terminated = await core.scaleDown(10);

      // Can only terminate 3 (from 5 down to min 2)
      expect(terminated).toBe(3);

      const stats = core.getStats();
      expect(stats.total).toBe(2);
      expect(stats.idle).toBe(2);
    });

    it("should not scale down below minimum", async () => {
      // Scale down to minimum first
      await core.scaleDown(3);

      // Try to scale down more
      const terminated = await core.scaleDown(2);

      // Should terminate 0
      expect(terminated).toBe(0);

      const stats = core.getStats();
      expect(stats.total).toBe(2);
    });

    it("should wait for busy workers during graceful shutdown", async () => {
      // Get an idle worker and assign a task
      const idleWorkers = core.getIdleWorkers();
      const worker = idleWorkers[0];

      // Simulate assigning task
      await core.assignTask(worker.id, "test-task", { value: 42 });

      const stats = core.getStats();
      expect(stats.busy).toBe(1);
      expect(stats.idle).toBe(4);

      // Try to scale down - should only terminate idle workers
      const terminated = await core.scaleDown(2);

      // Should terminate 2 idle workers, not the busy one
      expect(terminated).toBe(2);

      const newStats = core.getStats();
      expect(newStats.busy).toBe(1); // Busy worker still there
      expect(newStats.total).toBe(3);
    });

    it("should validate count parameter", async () => {
      // Zero count should be no-op
      const terminated = await core.scaleDown(0);

      expect(terminated).toBe(0);

      const stats = core.getStats();
      expect(stats.total).toBe(5);
    });

    it("should handle negative count", async () => {
      // Negative count should be no-op
      const terminated = await core.scaleDown(-1);

      expect(terminated).toBe(0);

      const stats = core.getStats();
      expect(stats.total).toBe(5);
    });

    it("should prevent concurrent scale operations", async () => {
      // Start two scale operations concurrently
      const scale1 = core.scaleDown(1);
      const scale2 = core.scaleDown(1);

      // One should fail with mutex error
      await expect(Promise.all([scale1, scale2])).rejects.toThrow(
        "Scaling operation already in progress"
      );
    });
  });

  describe("Worker Recycling", () => {
    it("should emit worker-recycled event for idle workers", async () => {
      // Configure with short idle timeout
      config = {
        ...config,
        minWorkerCount: 2,
        maxWorkerCount: 10,
      };
      core = new WorkerPoolCore(config);

      const recycledSpy = vi.fn();
      core.on("worker-recycled", recycledSpy);

      await core.initialize();
      await core.scaleUp(3); // Now have 5 workers

      // Manually trigger recycling with old idle times
      const idleWorkers = core.getIdleWorkers();
      const now = Date.now();
      for (const worker of idleWorkers) {
        // Make workers idle for more than default 5 minutes
        worker.lastActivityAt = now - 400000; // 6.67 minutes ago
      }

      // Manually call recycling (private method, so we trigger via timer simulation)
      // Since recycling is automatic via timer, we'll dispose to stop it
      await core.dispose();

      // Create new core to test recycling
      core = new WorkerPoolCore(config);
      await core.initialize();
    });

    it("should maintain minimum worker count during recycling", async () => {
      config = {
        ...config,
        minWorkerCount: 2,
      };
      core = new WorkerPoolCore(config);

      await core.initialize();

      // Workers should not be recycled below minimum
      const stats = core.getStats();
      expect(stats.total).toBeGreaterThanOrEqual(2);
    });
  });

  describe("Atomicity and Race Conditions", () => {
    it("should serialize scale-up and scale-down operations", async () => {
      await core.initialize();

      // Try concurrent scale up and down
      const scaleUp = core.scaleUp(2);

      // Wait a bit to ensure scaleUp starts
      await new Promise((resolve) => {
        setTimeout(resolve, 10);
      });

      const scaleDown = core.scaleDown(1);

      // One should fail due to mutex
      const results = await Promise.allSettled([scaleUp, scaleDown]);

      const rejected = results.filter((r) => r.status === "rejected");
      expect(rejected.length).toBeGreaterThanOrEqual(1);

      if (rejected[0].status === "rejected") {
        expect(rejected[0].reason.message).toContain("Scaling operation already in progress");
      }
    });

    it("should release mutex even on error", async () => {
      await core.initialize();

      // Try to scale up beyond max (will fail)
      await expect(core.scaleUp(20)).rejects.toThrow();

      // Mutex should be released, so next operation should work
      await core.scaleUp(1);

      const stats = core.getStats();
      expect(stats.total).toBe(3);
    });
  });

  describe("Event Emissions", () => {
    it("should emit scaled-up event with worker count", async () => {
      await core.initialize();

      const events: Array<{ count: number; total: number }> = [];
      core.on("scaled-up", (count: number, total: number) => {
        events.push({ count, total });
      });

      await core.scaleUp(3);

      expect(events).toHaveLength(1);
      expect(events[0]).toEqual({ count: 3, total: 5 });
    });

    it("should emit scaled-down event with worker count", async () => {
      await core.initialize();
      await core.scaleUp(3);

      const events: Array<{ count: number; total: number }> = [];
      core.on("scaled-down", (count: number, total: number) => {
        events.push({ count, total });
      });

      await core.scaleDown(2);

      expect(events).toHaveLength(1);
      expect(events[0]).toEqual({ count: 2, total: 3 });
    });

    it("should emit scale-error event on failure", async () => {
      await core.initialize();

      const errors: Error[] = [];
      core.on("scale-error", (error: Error) => {
        errors.push(error);
      });

      // Try to scale up beyond max
      await expect(core.scaleUp(20)).rejects.toThrow();

      // Should have captured error events during creation
      expect(errors.length).toBeGreaterThan(0);
    });
  });

  describe("Integration Scenarios", () => {
    it("should handle rapid scaling up and down", async () => {
      await core.initialize();

      // Scale up
      await core.scaleUp(3);
      expect(core.getStats().total).toBe(5);

      // Scale down
      await core.scaleDown(2);
      expect(core.getStats().total).toBe(3);

      // Scale up again
      await core.scaleUp(2);
      expect(core.getStats().total).toBe(5);

      // Scale down to minimum
      await core.scaleDown(10);
      expect(core.getStats().total).toBe(2);
    });

    it("should maintain pool integrity after multiple scaling operations", async () => {
      await core.initialize();

      // Perform multiple scaling operations
      await core.scaleUp(2);
      await core.scaleDown(1);
      await core.scaleUp(1);
      await core.scaleDown(1);

      // Pool should still be functional
      const stats = core.getStats();
      expect(stats.total).toBeGreaterThanOrEqual(config.minWorkerCount!);
      expect(stats.total).toBeLessThanOrEqual(config.maxWorkerCount!);
      expect(stats.idle).toBe(stats.total); // All should be idle
    });

    it("should clean up resources on dispose", async () => {
      await core.initialize();
      await core.scaleUp(3);

      const listenerCount = core.listenerCount("scaled-up");
      expect(listenerCount).toBeGreaterThanOrEqual(0);

      await core.dispose();

      // All listeners should be removed
      expect(core.listenerCount("scaled-up")).toBe(0);
      expect(core.listenerCount("scaled-down")).toBe(0);
      expect(core.listenerCount("scale-error")).toBe(0);
    });
  });
});

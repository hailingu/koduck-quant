{
  "name": "duck-flow",
  "private": true,
  "version": "2.3.0",
  "type": "module",
  "exports": {
    "./src/common/render/manager": "./src/common/render/render-manager/index.ts",
    "./src/common/render/manager/*": "./src/common/render/render-manager/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --no-warn-ignored",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "coverage:verify": "node ./scripts/verify-coverage.mjs",
    "coverage:digest": "node ./scripts/generate-coverage-digest.mjs",
    "coverage:upload:codecov": "node ./scripts/upload-coverage-codecov.mjs",
    "coverage:upload:coveralls": "node ./scripts/upload-coverage-coveralls.mjs",
    "coverage:upload:all": "npm run coverage:upload:codecov && npm run coverage:upload:coveralls",
    "coverage:track": "node ./scripts/track-coverage.mjs",
    "coverage:track:report": "node ./scripts/track-coverage.mjs --report",
    "test:dev": "vitest --watch --reporter=verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test test/e2e/smoke.spec.ts",
    "test:e2e:core": "playwright test test/e2e/entity-lifecycle.spec.ts test/e2e/flow-execution.spec.ts test/e2e/multi-tenant-isolation.spec.ts",
    "build:bundle": "vite build --outDir dist-ci-bundle --manifest",
    "bundle:check": "pnpm run build:bundle && node ./scripts/check-bundle-size.mjs --dist=dist-ci-bundle",
    "bundle:baseline": "pnpm run build:bundle && node ./scripts/check-bundle-size.mjs --dist=dist-ci-bundle --update-baseline",
    "build:di": "node ./scripts/build-di.mjs",
    "validate:deps": "node ./scripts/validate-dependency-graph.mjs",
    "chaos": "tsx scripts/chaos-runner.ts",
    "docs:api": "typedoc --options typedoc.json",
    "docs:api:watch": "typedoc --options typedoc.json --watch src",
    "docs:lint": "eslint 'src/**/*.ts' --rule 'jsdoc/require-jsdoc: error' --rule 'jsdoc/require-param: error' --rule 'jsdoc/require-returns: error'",
    "docs:lint:fix": "eslint 'src/**/*.ts' --rule 'jsdoc/require-jsdoc: warn' --fix",
    "docs:coverage": "node scripts/check-jsdoc-coverage.js",
    "docs:storybook": "storybook build -o docs/storybook",
    "docs:storybook:dev": "storybook dev -p 6006",
    "docs:build": "pnpm run docs:api && pnpm run docs:storybook",
    "config:sync-env": "tsx scripts/sync-env-artifacts.ts",
    "create:manager": "tsx scripts/create-scaffold.ts manager",
    "create:plugin": "tsx scripts/create-scaffold.ts plugin",
    "create:runtime": "tsx scripts/create-scaffold.ts runtime",
    "monitor:performance": "tsx scripts/performance-monitor.ts",
    "monitor:stability": "tsx scripts/stability-summary.ts",
    "ci": "pnpm run lint && pnpm run test:run"
  },
  "dependencies": {
    "nanoid": "^5.1.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.56.0",
    "@storybook/addon-essentials": "^8.3.5",
    "@storybook/addon-interactions": "^8.3.5",
    "@storybook/react": "^8.3.5",
    "@storybook/react-vite": "^8.3.5",
    "@storybook/test": "^8.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^3.2.4",
    "@webgpu/types": "^0.1.64",
    "canvas": "^3.2.0",
    "eslint": "^9.30.1",
    "eslint-plugin-jsdoc": "^50.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "glob": "^11.0.3",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "madge": "^8.0.0",
    "storybook": "^8.3.5",
    "tsx": "^4.20.6",
    "typedoc": "^0.26.10",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "yaml": "^2.7.0"
  }
}

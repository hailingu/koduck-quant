# ==========================================
# Koduck K8s Environment Configuration
# ==========================================
# 复制为 .env.dev 或 .env.prod 后修改对应值
# cp k8s/.env.template k8s/.env.dev
# cp k8s/.env.template k8s/.env.prod

# JWT Secret (APISIX consumer 和 backend 共享)
# 必须 >= 32 字符，开发和生产环境应使用不同的值
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Koduck Agent LLM config
# provider: minimax / deepseek / openai / kimi
LLM_PROVIDER=minimax

# For minimax:
# LLM_API_KEY=your_minimax_api_key
# LLM_API_BASE=https://api.minimax.chat/v1
# LLM_MODEL=MiniMax-M2.7

# For openai:
# LLM_API_KEY=your_openai_api_key
# LLM_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# For kimi:
# KIMI_API_KEY=your_kimi_api_key
# KIMI_API_BASE=https://api.kimi.com/coding/v1
# KIMI_MODEL=kimi-for-coding

LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=MiniMax-M2.7
KIMI_API_KEY=
KIMI_API_BASE=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-for-coding

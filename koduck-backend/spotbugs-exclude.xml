<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
      Constructor injection on Spring-managed classes can trigger EI_EXPOSE_REP2
      false positives because dependencies are framework-managed collaborators.
      Annotation-level suppression is intentionally banned in this project;
      use centralized SpotBugs filter rules instead.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>

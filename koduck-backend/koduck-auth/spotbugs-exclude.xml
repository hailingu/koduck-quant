<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- AuthUserPrincipal uses Lombok for builder/setter, authorities is immutable in practice -->
    <Match>
        <Class name="com.koduck.security.AuthUserPrincipal"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="com.koduck.security.AuthUserPrincipal$AuthUserPrincipalBuilder"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- AuthUserPrincipal.authorities is transient but set by Lombok builder, not deserialization -->
    <Match>
        <Class name="com.koduck.security.AuthUserPrincipal"/>
        <Bug pattern="SE_TRANSIENT_FIELD_NOT_RESTORED"/>
    </Match>
</FindBugsFilter>

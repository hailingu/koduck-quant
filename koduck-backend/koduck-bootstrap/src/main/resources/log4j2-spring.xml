<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="{&quot;timestamp&quot;:&quot;%d{yyyy-MM-dd'T'HH:mm:ss.SSS'Z',UTC}&quot;,&quot;logger&quot;:&quot;%c&quot;,&quot;level&quot;:&quot;%p&quot;,&quot;thread&quot;:&quot;%t&quot;,&quot;traceId&quot;:&quot;%X{traceId}&quot;,&quot;event&quot;:&quot;%enc{%m}{JSON}&quot;,&quot;stackTrace&quot;:&quot;%enc{%throwable}{JSON}&quot;}%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>

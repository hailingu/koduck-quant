# ==========================================
# Koduck Quant Docker Environment Configuration
# ==========================================
# Copy this file to .env and modify the values as needed
# cp .env.example .env

# ------------------------------------------
# Database Configuration
# ------------------------------------------
POSTGRES_DB=koduck_dev
POSTGRES_USER=koduck
POSTGRES_PASSWORD=koduck

# ------------------------------------------
# Redis Configuration
# ------------------------------------------
# Redis doesn't require password by default in development
# REDIS_PASSWORD=

# ------------------------------------------
# JWT Configuration
# ------------------------------------------
# IMPORTANT: Change this to a secure random string in production!
# Must be at least 32 characters long
JWT_SECRET=your-256-bit-secret-key-for-jwt-signing-must-be-at-least-32-characters-long

# ------------------------------------------
# Spring Boot Configuration
# ------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# ------------------------------------------
# Rate Limit Configuration
# ------------------------------------------
# Maximum failed login attempts per user within the window
RATE_LIMIT_LOGIN_FAILURE_MAX_PER_USER=5
# Maximum failed login attempts per IP within the window
RATE_LIMIT_LOGIN_FAILURE_MAX_PER_IP=20
# Login failure throttling window, supports Spring Duration values like 15m
RATE_LIMIT_LOGIN_FAILURE_WINDOW=15m
# Maximum password reset requests per user within the window
RATE_LIMIT_PASSWORD_RESET_MAX_PER_USER=3
# Maximum password reset requests per email within the window
RATE_LIMIT_PASSWORD_RESET_MAX_PER_EMAIL=5
# Maximum password reset requests per IP within the window
RATE_LIMIT_PASSWORD_RESET_MAX_PER_IP=10
# Password reset throttling window, supports Spring Duration values like 1h
RATE_LIMIT_PASSWORD_RESET_WINDOW=1h

# ------------------------------------------
# Data Service Configuration
# ------------------------------------------
DATA_SERVICE_API_KEY=

# ------------------------------------------
# Eastmoney Client Settings
# ------------------------------------------
# Cookie 有效期（秒），默认 3600（1小时），开发环境可设为 300（5分钟）调试
# EASTMONEY_COOKIE_TTL=3600
# 请求间隔（秒），默认 3.0，开发环境可设为 1.0 加快测试
# EASTMONEY_MIN_REQUEST_INTERVAL=3.0

# ------------------------------------------
# Feature Flags
# ------------------------------------------
# ENABLE_SWAGGER=true
# ENABLE_CORS=true

# ------------------------------------------
# Demo User Configuration
# ------------------------------------------
# Enable/disable demo user creation (default: false)
# APP_DEMO_ENABLED=false
# Demo username (default: demo)
# APP_DEMO_USERNAME=demo
# Demo password - REQUIRED when APP_DEMO_ENABLED=true
# APP_DEMO_PASSWORD=

# ------------------------------------------
# LLM API Configuration (for koduck-agent)
# ------------------------------------------
# MiniMax API Key
# MINIMAX_API_KEY=your_minimax_api_key_here

# DeepSeek API Key
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API Key
# OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API Base (optional)
# OPENAI_API_BASE=https://api.openai.com/v1

# Default LLM Provider (minimax/deepseek/openai)
# DEFAULT_LLM_PROVIDER=minimax
